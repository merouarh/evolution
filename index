}

/* ── TIME SLOTS ───────────────────────────────────────────── */
const timeSelect = document.getElementById('ftime');
if (timeSelect) {
  for (let h = 8; h < 19; h++) {
    for (let m of [0, 15, 30, 45]) {
      const hStr = h.toString().padStart(2, '0');
      const mStr = m.toString().padStart(2, '0');
