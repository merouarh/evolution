      pct = Math.max(2, Math.min(98, pct));
      const val = pct + '%';
      viewport.style.setProperty('--p', val);
      // update divider and handle positions (they read CSS var automatically via clip-path + left)
    }

    function posFromEvent(e) {
      const rect = viewport.getBoundingClientRect();
      const clientX = e.touches ? e.touches[0].clientX : e.clientX;
      return ((clientX - rect.left) / rect.width) * 100;
    }

    // Mouse
    viewport.addEventListener('mousedown', e => {
      dragging = true;
      setPosition(posFromEvent(e));
      e.preventDefault();
    });
    window.addEventListener('mousemove', e => {
      if (!dragging) return;
      setPosition(posFromEvent(e));
    });
    window.addEventListener('mouseup', () => { dragging = false; });

    // Touch
    viewport.addEventListener('touchstart', e => {
      dragging = true;
      setPosition(posFromEvent(e));
    }, { passive: true });
    viewport.addEventListener('touchmove', e => {
      if (!dragging) return;
      setPosition(posFromEvent(e));
      e.preventDefault();
    }, { passive: false });
    viewport.addEventListener('touchend', () => { dragging = false; });
  }

  // Init all current visible sliders
  document.querySelectorAll('.ba-comparison').forEach(vp => {
    initSlider(vp);
    vp._sliderReady = true;
  });

  // Expose so filters / "voir plus" can init newly-revealed ones
  window._initBASlider = initSlider;
})();

/* ── BEFORE / AFTER — Voir plus ───────────────────────────── */
let baExpanded = false;
function toggleBA() {
  baExpanded = !baExpanded;
  const hiddenCards = document.querySelectorAll('.ba-card[data-hidden-by-toggle]');
  if (baExpanded) {
    // reveal hidden cards
    document.querySelectorAll('.ba-card').forEach(c => {
      if (c.dataset.hiddenByToggle) {
        c.classList.remove('hidden');
        c.removeAttribute('data-hidden-by-toggle');
        // init slider if not done yet
        const vp = c.querySelector('.ba-comparison');
        if (vp && !vp._sliderReady) {
          window._initBASlider(vp);
          vp._sliderReady = true;
        }
      }
    });
    document.getElementById('baToggle').textContent = '✦ Voir moins';
  } else {
    // collapse — re-hide them
    document.querySelectorAll('.ba-card').forEach((c, i) => {
      if (i >= 4) {
        c.classList.add('hidden');
        c.dataset.hiddenByToggle = '1';
      }
    });
    document.getElementById('baToggle').textContent = '✦ Voir plus de résultats';
  }
}

// Mark initially-hidden cards
document.querySelectorAll('.ba-card.hidden').forEach(c => {
  c.dataset.hiddenByToggle = '1';
});

/* ── BEFORE / AFTER — Filter ──────────────────────────────── */
document.querySelectorAll('.filter-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const filter = tab.dataset.filter;
    document.querySelectorAll('.ba-card').forEach(card => {
      const match = filter === 'all' || card.dataset.category === filter;
      // Don't unhide cards hidden by "voir plus" toggle unless expanded
      const toggleHidden = !!card.dataset.hiddenByToggle;
      if (match && !toggleHidden) {
        card.classList.remove('hidden');
      } else if (!match) {
        card.classList.add('hidden');
      }
      // init slider if newly visible
      if (match && !toggleHidden) {
        const vp = card.querySelector('.ba-comparison');
        if (vp && !vp._sliderReady) {
          window._initBASlider(vp);
          vp._sliderReady = true;
        }
      }
    });
  });
});

/* ── GALLERY SLIDER ───────────────────────────────────────── */
const track = document.getElementById('galleryTrack');
const slides = document.querySelectorAll('.gallery-slide');
const dotsContainer = document.getElementById('galleryDots');
let currentSlide = 0;
let slidesPerView = 3;

function getSlidesPerView() {
  if (window.innerWidth <= 480) return 1;
  if (window.innerWidth <= 768) return 2;
  return 3;
}

function buildDots() {
  dotsContainer.innerHTML = '';
  const total = Math.ceil(slides.length / slidesPerView);
  for (let i = 0; i < total; i++) {
    const dot = document.createElement('div');
    dot.className = 'gallery-dot' + (i === currentSlide ? ' active' : '');
    dot.addEventListener('click', () => goToSlide(i));
    dotsContainer.appendChild(dot);
  }
}

function goToSlide(idx) {
  slidesPerView = getSlidesPerView();
  const maxIdx = Math.max(0, Math.ceil(slides.length / slidesPerView) - 1);
  currentSlide = Math.max(0, Math.min(idx, maxIdx));
  const slideWidth = slides[0].offsetWidth + 19.2; // gap ~1.2rem
  track.style.transform = `translateX(-${currentSlide * slidesPerView * slideWidth}px)`;
  document.querySelectorAll('.gallery-dot').forEach((d, i) => d.classList.toggle('active', i === currentSlide));
}

document.getElementById('galleryPrev').addEventListener('click', () => goToSlide(currentSlide - 1));
document.getElementById('galleryNext').addEventListener('click', () => goToSlide(currentSlide + 1));

window.addEventListener('resize', () => { slidesPerView = getSlidesPerView(); buildDots(); goToSlide(0); });

setTimeout(() => { slidesPerView = getSlidesPerView(); buildDots(); }, 100);

// Auto-play gallery
setInterval(() => {
  const maxIdx = Math.ceil(slides.length / slidesPerView) - 1;
  goToSlide(currentSlide < maxIdx ? currentSlide + 1 : 0);
}, 4500);

/* ── LAZY LOAD IMAGES ─────────────────────────────────────── */
if ('IntersectionObserver' in window) {
  const imgObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const img = entry.target;
        if (img.dataset.src) {
          img.src = img.dataset.src;
          img.removeAttribute('data-src');
        }
        imgObserver.unobserve(img);
      }
    });
  }, { rootMargin: '200px' });
  document.querySelectorAll('img[loading="lazy"]').forEach(img => imgObserver.observe(img));
}
</script>
