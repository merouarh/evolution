/* ── GOOGLE APPS SCRIPT CONFIG ────────────────────────────── */
const GAS_URL = 'https://script.google.com/macros/s/AKfycbzIIxFDDoVISjqvJOeVwnCBBmX3BGUwitIrHHT-TtneYgbhegP1HutbS_u18_sLAbo/exec';

/* ── LOAD BOOKED SLOTS FROM GOOGLE SHEETS ─────────────────── */
async function refreshBookedSlots() {
  const service = document.getElementById('fservice').value;
  const date    = document.getElementById('fdate').value;
  if (!service || !date) return;

  try {
    const url = `${GAS_URL}?service=${encodeURIComponent(service)}&date=${encodeURIComponent(date)}`;
    const res  = await fetch(url);
    const json = await res.json();

    if (!json.success || !Array.isArray(json.bookedTimes)) return;

    const sel = document.getElementById('ftime');
    sel.querySelectorAll('option').forEach(opt => {
      if (!opt.value) return; // skip placeholder
      const booked = json.bookedTimes.includes(opt.value);
      opt.disabled    = booked;
      // show "— Réservé" label on taken slots
      opt.textContent = booked
        ? opt.value.replace(':','h') + ' — Réservé ✗'
        : opt.value.replace(':','h') + (opt.value.split(':')[1] === '00' ? '00' : '');
    });

    // if currently selected slot just became blocked, reset it
    const currentOpt = sel.options[sel.selectedIndex];
    if (currentOpt && currentOpt.disabled) sel.value = '';

  } catch (err) {
    console.warn('Impossible de charger les créneaux :', err);
  }
}

// Trigger slot refresh when service or date changes
document.getElementById('fservice').addEventListener('change', function() {
  updateSubServices(this.value);
  refreshBookedSlots();
});
document.getElementById('fdate').addEventListener('change', refreshBookedSlots);

/* ── FORM SUBMIT → GOOGLE SHEETS ──────────────────────────── */
async function handleFormSubmit(e) {
  e.preventDefault();
  const form  = e.target;
  const btn   = document.getElementById('submitBtn');
  const msgEl = document.getElementById('formMessage');

  // Reset message
  msgEl.className   = 'form-message';
  msgEl.style.display = 'none';
  msgEl.textContent = '';

  // Collect values
  const data = {
    nom         : document.getElementById('fname').value.trim(),
    telephone   : document.getElementById('fphone').value.trim(),
    service     : document.getElementById('fservice').value,
    sous_service: document.getElementById('fsubservice').value,
    date        : document.getElementById('fdate').value,
    heure       : document.getElementById('ftime').value,
    notes       : document.getElementById('fnotes').value.trim()
  };

  // Front-end validation
  if (!data.nom || !data.telephone || !data.service || !data.date || !data.heure) {
    msgEl.textContent   = '⚠️ Veuillez remplir tous les champs obligatoires (Nom, Téléphone, Service, Date, Heure).';
    msgEl.className     = 'form-message error';
    msgEl.style.display = 'block';
    msgEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    return;
  }

  // UI loading state
  btn.disabled    = true;
  btn.textContent = '⏳ Envoi en cours...';

  try {
    // POST to Google Apps Script — no-cors because GAS doesn't return CORS headers
    // The data WILL be written to Sheets even with no-cors
    await fetch(GAS_URL, {
      method  : 'POST',
      mode    : 'no-cors', // required for GAS Web Apps from browser
      headers : { 'Content-Type': 'application/json' },
      body    : JSON.stringify(data)
    });

    // With no-cors we can't read the response body, so we show a success message
    // The anti-duplicate check still runs server-side in Apps Script
    msgEl.textContent   = `✅ Merci ${data.nom} ! Votre demande de rendez-vous pour le ${formatDate(data.date)} à ${data.heure} a bien été envoyée. Notre équipe vous confirmera sous 24h.`;
    msgEl.className     = 'form-message success';
    msgEl.style.display = 'block';

    // Reset form
    form.reset();
    document.getElementById('fsubservice').innerHTML = '<option value="">— Sélectionnez un service d\'abord —</option>';

    // Refresh slots to reflect any new booking
    setTimeout(refreshBookedSlots, 1500);

  } catch (err) {
    msgEl.textContent   = `❌ Erreur réseau : impossible d'envoyer la demande. Veuillez contacter la clinique via WhatsApp.`;
    msgEl.className     = 'form-message error';
    msgEl.style.display = 'block';
    console.error('Booking fetch error:', err);
  } finally {
    btn.disabled    = false;
    btn.textContent = '📅 Confirmer mon rendez-vous';
    msgEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
}

function formatDate(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}

