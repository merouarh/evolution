/* The comparison viewport */
.ba-comparison {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  user-select: none;
  -webkit-user-select: none;
  cursor: col-resize;
}

/* Both images fill the viewport */
.ba-img-before,
.ba-img-after {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
}

/* "After" image is clipped to the RIGHT half of the slider handle — JS sets this via CSS variable */
.ba-img-after {
  /* default: show right 50% (handle at 50%) */
  clip-path: inset(0 0 0 50%);
  transition: none; /* dragging needs no transition; CSS var updated in JS */
}

/* When JS updates the position it writes: style="--p: 60%" on .ba-comparison */
.ba-comparison .ba-img-after {
  clip-path: inset(0 0 0 var(--p, 50%));
}

/* Vertical divider line */
.ba-divider {
  position: absolute;
  top: 0;
  left: var(--p, 50%);
  transform: translateX(-50%);
  width: 2px;
  height: 100%;
  background: white;
  z-index: 3;
  pointer-events: none;
}

/* Round drag handle */
.ba-handle {
  position: absolute;
  top: 50%;
  left: var(--p, 50%);
  transform: translate(-50%, -50%);
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: white;
  border: 2.5px solid rgba(212,194,165,0.9);
