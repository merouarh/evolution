};

function updateSubServices(service) {
  const sub = document.getElementById('fsubservice');
  sub.innerHTML = '<option value="">— Choisir un sous-service —</option>';
  if (subServices[service]) {
    subServices[service].forEach(s => {
      const opt = document.createElement('option');
      opt.value = s;
      opt.textContent = s;
      sub.appendChild(opt);
    });
  } else {
    sub.innerHTML = '<option value="">— Sélectionnez un service d\'abord —</option>';
